# Disabled apps (comma-separated). Apps are enabled by default.
# Valid values: addresses, cross-chain
NEXT_PUBLIC_DISABLED_APPS=

# Optional: Custom RPC for ENS resolution
# MAINNET_RPC_URL=

# --- E2E anvil fork (examples/ui/scripts/start-anvil-fork.mjs) ---
# All values below are optional; sensible defaults are applied.
#
# Upstream RPC the anvil fork reads from. Defaults to Base Sepolia public node.
# ANVIL_FORK_RPC=https://base-sepolia-rpc.publicnode.com
#
# Port anvil listens on. Must match NEXT_PUBLIC_ANVIL_URL.
# ANVIL_PORT=8545
#
# How many blocks behind `latest` anvil should fork. Defaults to 32. Raise it
# if the upstream RPC prunes more aggressively; keep it well under the node's
# retention window (~128 blocks for publicnode.com).
# ANVIL_FORK_BLOCK_OFFSET=32
#
# Hard-pin the fork block (escape hatch). When set, overrides the offset logic.
# ANVIL_FORK_BLOCK=
